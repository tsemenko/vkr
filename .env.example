# Django
SECRET_KEY=change-me
DEBUG=1
ALLOWED_HOSTS=127.0.0.1,localhost,192.168.56.102

# Подключение к контроллеру домена через WinRM
DC_HOST=192.168.56.10
DC_WINRM_PORT=5985
DC_WINRM_TRANSPORT=ntlm
DC_WINRM_USER=LAB\svc.account.creator
DC_WINRM_PASSWORD=change-me

# Домен и правила именования
AD_DOMAIN_NETBIOS=LAB
AD_UPN_SUFFIX=@lab.local
AD_HOME_PAGE=https://portal.muiv.ru
AD_DEFAULT_PASSWORD=change-me

# Филиалы
BRANCH_HQ_LABEL=1
BRANCH_SPOSAD_LABEL=Филиал в г. Сергиев Посад
BRANCH_PENZA_LABEL=Филиал в г. Пенза
BRANCH_RYAZAN_LABEL=Филиал в г. Рязань
BRANCH_ROSTOV_LABEL=Филиал в г. Ростов-на-Дону
BRANCH_NNOV_LABEL=Филиал в г. Нижний Новгород

# OU для создания учетных записей
OU_HQ=OU=all,OU=Managed,OU=Domain Users,DC=lab,DC=local
OU_SPOSAD=OU=sposad,OU=branches,OU=Unmanaged,OU=Domain Users,DC=lab,DC=local
OU_PENZA=OU=penza,OU=branches,OU=Unmanaged,OU=Domain Users,DC=lab,DC=local
OU_RYAZAN=OU=ryazan,OU=branches,OU=Unmanaged,OU=Domain Users,DC=lab,DC=local
OU_ROSTOV=OU=rostov,OU=branches,OU=Unmanaged,OU=Domain Users,DC=lab,DC=local
OU_NNOV=OU=nnov,OU=branches,OU=Unmanaged,OU=Domain Users,DC=lab,DC=local

# Профили и домашние папки
PROFILE_HQ=\\serverf\pr\{login}
HOME_HQ=\\serverhf\hf\{login}
PROFILE_BRANCH=\\serverf\bpr\{login}
FILESHARES_ENABLED=0

# Логирование операций во внешние файлы
LOGGING_ENABLED=0
LOG_FILE1=\\serverd0\c$\Windows\Logs\ADWeb\CreatedUsers.txt
LOG_FILE2=\\serverd1\c$\Windows\Logs\ADWeb\CreatedUsers.txt

# Группы AD по умолчанию
GROUPS_HQ=1c_Sirius_tolst,1c_Sirius_tonk,Allow Images,~Всем сотрудникам университета,usb_read_only,Internet_Basic
GROUPS_HQ_F=8 марта
GROUPS_BRANCH=1c_Sirius_tolst,1c_Sirius_tonk,branche_portal,~Всем Филиалам,external terminal,external terminal2
GROUPS_BRANCH_F=8 марта филиалы

# Exchange
EXCHANGE_ENABLED=0
EXCHANGE_URI=http://serverexcha.miemp.ru/PowerShell/
EXCHANGE_AUTH=Kerberos
EXCHANGE_USER=MIEMP\exchange_admin
EXCHANGE_PASSWORD=change-me
MAILBOX_DB_HQ=mailbox500
MAILBOX_DB_BRANCH=mailbox50
SMTP_SUFFIX_BRANCH=@muiv.ru

# LDAP-вход в веб-интерфейс
LDAP_ENABLED=0
LDAP_SERVER_URI=ldap://dc01.lab.local:389
LDAP_BIND_DN=CN=svc_ldap,OU=Admin,OU=Managed,OU=Domain Users,DC=lab,DC=local
LDAP_BIND_PASSWORD=change-me
LDAP_USER_BASE_DN=DC=lab,DC=local
LDAP_GROUP_BASE_DN=DC=lab,DC=local
LDAP_REQUIRE_GROUP=
LDAP_GROUP_ADMINS_DN=
LDAP_GROUP_OPERATORS_DN=

# Мониторинг, Redis и Celery
AD_USERS_SEARCH_BASE=OU=all,OU=Managed,OU=Domain Users,DC=lab,DC=local
AD_ANALYTICS_MAX_DAYS=10
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
MONITORING_CACHE_KEY=ad_monitoring_snapshot
MONITORING_CACHE_TIMEOUT=120
MONITORING_REFRESH_SECONDS=60
MONITORING_FRAGMENT_POLL_SECONDS=60
MONITORING_FORCE_SYNC_ON_MISS=1
